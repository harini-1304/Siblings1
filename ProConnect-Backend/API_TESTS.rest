### ProConnect Backend API Testing
### Use with VS Code REST Client extension or import to Postman

@baseUrl = http://localhost:5000
@facultyToken = 

# ============================================================
# HEALTH CHECK
# ============================================================

### Health Check
GET {{baseUrl}}/api/health

# ============================================================
# AUTHENTICATION ROUTES
# ============================================================

### Faculty Signup
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{
  "email": "test.faculty@psgitech.ac.in",
  "password": "Test@1234",
  "employee_id": "EMP12345",
  "name": "Test Faculty"
}

### Faculty Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "test.faculty@psgitech.ac.in",
  "password": "Test@1234"
}

### Verify Token
POST {{baseUrl}}/api/auth/verify-token
Content-Type: application/json

{
  "token": "{{facultyToken}}"
}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh-token
Content-Type: application/json

{
  "token": "{{facultyToken}}"
}

