### Get All Students (Faculty Only)
GET {{baseUrl}}/api/students?branch=CSE&section=A&page=1&limit=10
Authorization: Bearer {{facultyToken}}

### Get Single Student (Faculty Only)
GET {{baseUrl}}/api/students/STUDENT_ID_HERE
Authorization: Bearer {{facultyToken}}

### Update Student (Faculty Only)
PUT {{baseUrl}}/api/students/STUDENT_ID_HERE
Authorization: Bearer {{facultyToken}}
Content-Type: application/json

{
  "basic_info": {
    "student_name": "Updated Name",
    "roll_number": "19BCE001",
    "mobile_no": "9876543210",
    "parent_mobile": "9876543211",
    "personal_mail": "john@email.com",
    "college_mail": "john@psgtech.ac.in",
    "branch": "CSE",
    "section": "A",
    "year": "4"
  }
}

### Delete Student (Faculty Only)
DELETE {{baseUrl}}/api/students/STUDENT_ID_HERE
Authorization: Bearer {{facultyToken}}

# ============================================================
# FACULTY ROUTES
# ============================================================

### Get Faculty Profile
GET {{baseUrl}}/api/faculty/profile
Authorization: Bearer {{facultyToken}}

### Change Password
POST {{baseUrl}}/api/faculty/change-password
Authorization: Bearer {{facultyToken}}
Content-Type: application/json

{
  "current_password": "Test@1234",
  "new_password": "NewPassword@1234"
}

### Get Statistics
GET {{baseUrl}}/api/faculty/stats
Authorization: Bearer {{facultyToken}}

